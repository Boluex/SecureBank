# SecureBank backend environment configuration.
# Copy this file to `.env` and replace every placeholder with a real value.
# NEVER commit the resulting `.env` file to source control.

# PostgreSQL connection string used by SQLAlchemy.
DATABASE_URL=postgresql://user:password@localhost:5432/securebank

# Generic application secret (used for miscellaneous signing / CSRF salts).
SECRET_KEY=generate-a-strong-secret-key

# Paths to the RSA key pair used to sign and verify JWTs with RS256.
# Generate them with ./generate_keys.sh
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem

# Fernet symmetric key used to encrypt account balances at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-with-fernet

# JWT lifetimes.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of origins allowed by CORS (the React dev server).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Maximum amount permitted for a single deposit or withdrawal.
MAX_TRANSACTION_AMOUNT=1000000

# Debug mode. When "true", auth cookies are issued WITHOUT the Secure flag so
# the React dev server can use them over plain http://localhost. Keep this
# "true" for local development; in production set it to "false" and serve the
# API over HTTPS so cookies are only ever sent on secure connections.
DEBUG=true
